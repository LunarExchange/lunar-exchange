{
  "name": "@lunarexchange/lunar-exchange",
  "version": "1.0.0",
  "description": "Modern Stellar Network Trading Platform - A reinvented trading terminal for the Stellar blockchain",
  "author": "LunarExchange Organization",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/lunarexchange/lunar-exchange.git"
  },
  "bugs": {
    "url": "https://github.com/lunarexchange/lunar-exchange/issues"
  },
  "homepage": "https://lunar-exchange.io",
  "keywords": [
    "stellar",
    "blockchain",
    "cryptocurrency",
    "trading",
    "exchange",
    "dex",
    "stellar-network"
  ],
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "scripts": {
    "setup": "npm install",
    "dev": "webpack serve --config=configs/webpack.dev.js --open",
    "start": "npm run dev",
    "build": "npm run clean && webpack --config=configs/webpack.prod.js",
    "build:analyze": "npm run build -- --analyze",
    "production": "npm run build",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint . --ext .js,.jsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "fix-eslint": "node scripts/fix-eslint.js",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css,scss}\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist/*",
    "hash": "cd dist && openssl dgst -sha256 index.html",
    "validate": "npm run lint && npm run format:check && npm run test",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "@ledgerhq/hw-app-str": "^7.2.4",
    "@ledgerhq/hw-transport-webusb": "^6.29.8",
    "@stellar-broker/client": "^0.6.13",
    "@stellar/freighter-api": "^1.4.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "@stellarguard/stellar-uri": "^1.1.1",
    "@trezor/connect-plugin-stellar": "^9.0.6",
    "@trezor/connect-web": "^9.5.4",
    "@walletconnect/sign-client": "^2.4.6",
    "awesome-debounce-promise": "^2.1.0",
    "bignumber.js": "^9.1.1",
    "d3": "^7.9.0",
    "fast-average-color": "^9.4.0",
    "is-electron": "^2.2.2",
    "lightweight-charts": "^4.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.0",
    "prop-types": "^15.8.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-input-autosize": "^3.0.0",
    "react-router-dom": "^6.21.0",
    "react-virtualized": "^9.22.5",
    "screenfull": "^6.0.2",
    "stellar-identicon-js": "^1.0.0",
    "whatwg-fetch": "^3.6.20",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.8",
    "@babel/eslint-parser": "^7.25.8",
    "@babel/plugin-transform-modules-commonjs": "^7.25.7",
    "@babel/preset-env": "^7.25.8",
    "@babel/preset-react": "^7.25.7",
    "@babel/preset-typescript": "^7.25.7",
    "@storybook/addon-essentials": "^7.6.7",
    "@storybook/addon-interactions": "^7.6.7",
    "@storybook/addon-links": "^7.6.7",
    "@storybook/react": "^7.6.7",
    "@storybook/react-webpack5": "^7.6.7",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.5",
    "eslint": "^8.56.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.0",
    "https-browserify": "^1.0.0",
    "husky": "^8.0.3",
    "image-minimizer-webpack-plugin": "^4.1.0",
    "imagemin": "^9.0.0",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-jpegtran": "^8.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^11.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "mini-css-extract-plugin": "^2.9.1",
    "mini-svg-data-uri": "^1.4.4",
    "prettier": "^3.1.1",
    "process": "^0.11.10",
    "rimraf": "^5.0.5",
    "sass": "^1.79.5",
    "sass-loader": "^16.0.2",
    "stream-http": "^3.2.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.3.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.95.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0",
    "webpack-merge": "^6.0.1"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
